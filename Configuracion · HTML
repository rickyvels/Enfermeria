    <script src="app.js"></script>
    <script>
        // ── Utilidades de color ──────────────────────────
        function hexToRgb(hex) {
            const r = parseInt(hex.slice(1,3),16);
            const g = parseInt(hex.slice(3,5),16);
            const b = parseInt(hex.slice(5,7),16);
            return {r,g,b};
        }
        function isDark(hex) {
            const {r,g,b} = hexToRgb(hex);
            return (0.299*r + 0.587*g + 0.114*b) < 160;
        }
        function lighten(hex, amt) {
            const {r,g,b} = hexToRgb(hex);
            return '#' + [r,g,b].map(v => Math.min(255,v+amt).toString(16).padStart(2,'0')).join('');
        }
        function darken(hex, amt) {
            const {r,g,b} = hexToRgb(hex);
            return '#' + [r,g,b].map(v => Math.max(0,v-amt).toString(16).padStart(2,'0')).join('');
        }
        function alpha(hex, a) {
            const {r,g,b} = hexToRgb(hex);
            return `rgba(${r},${g},${b},${a})`;
        }
        function isValidHex(hex) { return /^#[0-9a-fA-F]{6}$/.test(hex); }

        // ── Aplicar colores al sidebar real de esta página ──
        function aplicarSidebar(sbHex) {
            if(!isValidHex(sbHex)) return;
            const dark = isDark(sbHex);
            const text = dark ? '#e2e8f0' : darken(sbHex, 120);
            const activeB = dark ? alpha('#fff',0.12) : alpha(darken(sbHex,120),0.15);
            const borderC = dark ? alpha('#fff',0.12) : alpha(darken(sbHex,120),0.15);

            document.getElementById('sidebar').style.background = sbHex;
            document.getElementById('sidebarLogo').style.color = text;
            for(let i=1;i<=8;i++){
                const el = document.getElementById('ni'+i);
                if(!el) continue;
                el.style.color = text;
                if(el.classList.contains('active')) {
                    el.style.background = activeB;
                    el.style.borderLeftColor = text;
                } else {
                    el.style.background = '';
                    el.style.borderLeftColor = 'transparent';
                }
            }
            document.getElementById('navDiv').style.background  = borderC;
            document.getElementById('navDiv2').style.background = borderC;
        }

        function aplicarTopbar(sbHex, tbHex) {
            if(!isValidHex(tbHex)) return;
            const tbDark = isDark(tbHex);
            const titleColor = tbDark ? lighten(sbHex, 60) : darken(sbHex, 80);
            const subColor   = tbDark ? lighten(sbHex, 20) : darken(sbHex, 50);

            document.getElementById('topbar').style.background = tbHex;
            document.getElementById('topTitle').style.color    = titleColor;
            document.getElementById('topSub').style.color      = subColor;
            document.getElementById('btnSave').style.background = tbHex;
        }

        // ── Aplicar colores a la PREVIEW ──────────────────
        function aplicarPreview(sbHex, tbHex) {
            if(!isValidHex(sbHex) || !isValidHex(tbHex)) return;
            const sbDark = isDark(sbHex);
            const tbDark = isDark(tbHex);
            const sbText  = sbDark ? '#e2e8f0' : darken(sbHex, 120);
            const sbActB  = sbDark ? alpha('#fff',0.12) : alpha(darken(sbHex,120),0.15);
            const sbBord  = sbDark ? alpha('#fff',0.12) : alpha(darken(sbHex,120),0.15);
            const tbTitle = tbDark ? lighten(sbHex, 60) : darken(sbHex, 80);
            const tbSub   = tbDark ? lighten(sbHex, 20) : darken(sbHex, 50);
            const bdgClr  = sbDark ? lighten(sbHex, 60) : sbHex;

            document.getElementById('prevSb').style.background = sbHex;
            document.getElementById('prevLogo').style.color = sbText;
            ['pni1','pni2','pni3','pni4','pni5'].forEach((id,i) => {
                const el = document.getElementById(id);
                el.style.color = sbText;
                if(id==='pni1') { el.style.background = sbActB; el.style.borderLeftColor = sbText; }
            });
            document.getElementById('prevNdiv').style.background = sbBord;

            document.getElementById('prevTopbar').style.background = tbHex;
            document.getElementById('prevTitle').style.color  = tbTitle;
            document.getElementById('prevSub').style.color    = tbSub;
            const bdg = document.getElementById('prevBadge');
            bdg.style.background  = alpha(sbHex, 0.15);
            bdg.style.color       = bdgClr;
            bdg.style.borderColor = alpha(sbHex, 0.3);

            [1,2,3,4].forEach(i => {
                const card = document.getElementById('pcard'+i);
                const num  = document.getElementById('pcnum'+i);
                card.style.borderTopWidth = '3px';
                card.style.borderTopStyle = 'solid';
                if(i%2!==0) { card.style.borderTopColor = tbHex; num.style.color = tbHex; }
                else         { card.style.borderTopColor = sbHex; num.style.color = sbHex; }
            });

            document.getElementById('prevActTitle').style.color = tbHex;
            document.getElementById('pai1').style.borderLeftColor = tbHex;
            document.getElementById('pai2').style.borderLeftColor = sbHex;
            document.getElementById('pai3').style.borderLeftColor = tbHex;
        }

        // ── Sincronizar inputs ────────────────────────────
        function sync(type, hex) {
            if(!isValidHex(hex)) return;
            if(type==='sidebar') {
                document.getElementById('sidebarColor').value = hex;
                document.getElementById('sidebarHex').value   = hex;
            } else {
                document.getElementById('topbarColor').value = hex;
                document.getElementById('topbarHex').value   = hex;
            }
            const sb = document.getElementById('sidebarHex').value;
            const tb = document.getElementById('topbarHex').value;
            aplicarPreview(sb, tb);
            aplicarSidebar(sb);
            aplicarTopbar(sb, tb);
        }

        // ── Guardar en localStorage ───────────────────────
        function guardarColores() {
            const sb = document.getElementById('sidebarHex').value;
            const tb = document.getElementById('topbarHex').value;
            if(!isValidHex(sb) || !isValidHex(tb)) return;
            localStorage.setItem('nc_sidebar', sb);
            localStorage.setItem('nc_topbar',  tb);
            const toast = document.getElementById('toast');
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2500);
        }

        function resetearColores() {
            localStorage.removeItem('nc_sidebar');
            localStorage.removeItem('nc_topbar');
            sync('sidebar','#2EC4B6');
            sync('topbar', '#0a3d38');
            document.querySelectorAll('.preset').forEach(p => {
                p.classList.remove('active');
                if(p.dataset.color==='#2EC4B6' && p.dataset.target==='sidebar') p.classList.add('active');
                if(p.dataset.color==='#0a3d38' && p.dataset.target==='topbar')  p.classList.add('active');
            });
        }

        // ── Eventos ───────────────────────────────────────
        document.getElementById('sidebarColor').addEventListener('input', e => sync('sidebar', e.target.value));
        document.getElementById('topbarColor').addEventListener('input',  e => sync('topbar',  e.target.value));
        document.getElementById('sidebarHex').addEventListener('input',   e => sync('sidebar', e.target.value));
        document.getElementById('topbarHex').addEventListener('input',    e => sync('topbar',  e.target.value));

        document.querySelectorAll('.preset').forEach(p => {
            p.addEventListener('click', () => {
                const target = p.dataset.target;
                document.querySelectorAll('.preset').forEach(x => { if(x.dataset.target===target) x.classList.remove('active'); });
                p.classList.add('active');
                sync(target, p.dataset.color);
            });
        });

        // ── Cargar colores guardados al iniciar ───────────
        (function init() {
            const sb = localStorage.getItem('nc_sidebar') || '#2EC4B6';
            const tb = localStorage.getItem('nc_topbar')  || '#0a3d38';
            document.getElementById('sidebarHex').value   = sb;
            document.getElementById('sidebarColor').value = sb;
            document.getElementById('topbarHex').value    = tb;
            document.getElementById('topbarColor').value  = tb;
            document.querySelectorAll('.preset').forEach(p => {
                p.classList.remove('active');
                if(p.dataset.color===sb && p.dataset.target==='sidebar') p.classList.add('active');
                if(p.dataset.color===tb && p.dataset.target==='topbar')  p.classList.add('active');
            });
            aplicarPreview(sb, tb);
            aplicarSidebar(sb);
            aplicarTopbar(sb, tb);
        })();
    </script>
</body>
</html>
