<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración — NurseCore</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Inter',sans-serif; background:#f8fafc; min-height:100vh; display:flex; }

        /* ── Sidebar (usa colores guardados) ── */
        .sidebar {
            width:240px; min-height:100vh;
            padding:28px 16px; display:flex; flex-direction:column;
            gap:6px; position:fixed; top:0; left:0; z-index:10;
        }
        .sidebar-logo { font-size:22px; font-weight:700; padding:0 10px; margin-bottom:28px; letter-spacing:-0.5px; }
        .sidebar-logo span { font-weight:400; opacity:0.55; font-size:11px; display:block; margin-top:2px; letter-spacing:0.08em; text-transform:uppercase; }
        .nav-item {
            display:flex; align-items:center; gap:10px; padding:12px 14px;
            border-radius:14px; font-size:14px; font-weight:500; text-decoration:none;
            transition:all 0.2s ease; border-left:3px solid transparent;
        }
        .nav-item:hover { transform:translateX(4px); }
        .nav-item.active { font-weight:600; }
        .nav-divider { height:1px; margin:8px 10px; }

        .main { margin-left:240px; flex:1; min-height:100vh; }

        /* ── Topbar ── */
        .topbar { padding:22px 36px; display:flex; justify-content:space-between; align-items:center; }
        .page-title { font-size:28px; font-weight:700; letter-spacing:-0.5px; }
        .page-subtitle { font-size:13px; margin-top:4px; }

        /* ── Contenido ── */
        .content { padding:28px 36px; display:grid; grid-template-columns:1fr 1fr; gap:24px; align-items:start; }

        .panel {
            background:#fff; border-radius:18px; padding:24px;
            border:0.5px solid #e2e8f0;
        }
        .panel-title {
            font-size:15px; font-weight:600; color:#0f172a;
            margin-bottom:18px; display:flex; align-items:center; gap:8px;
        }
        .panel-title::after { content:''; flex:1; height:0.5px; background:#e2e8f0; }

        .field { margin-bottom:16px; }
        .field label { display:block; font-size:12px; font-weight:500; color:#64748b; margin-bottom:8px; text-transform:uppercase; letter-spacing:0.05em; }
        .color-row { display:flex; align-items:center; gap:10px; }
        .color-row input[type=color] {
            width:44px; height:44px; border:0.5px solid #e2e8f0;
            border-radius:12px; cursor:pointer; padding:3px; background:#fff;
        }
        .color-row input[type=text] {
            flex:1; padding:11px 14px; border:0.5px solid #e2e8f0;
            border-radius:12px; font-size:13px; font-family:monospace;
            color:#0f172a; background:#f8fafc; outline:none;
        }
        .color-row input[type=text]:focus { border-color:#2EC4B6; background:#fff; }

        .presets-label { font-size:12px; font-weight:500; color:#64748b; margin-bottom:8px; text-transform:uppercase; letter-spacing:0.05em; }
        .presets { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:18px; }
        .preset {
            width:32px; height:32px; border-radius:10px; cursor:pointer;
            border:2px solid transparent; transition:transform 0.15s, border-color 0.15s;
            position:relative;
        }
        .preset:hover { transform:scale(1.15); }
        .preset.active { border-color:#0f172a; }
        .preset .preset-tip {
            display:none; position:absolute; bottom:calc(100% + 6px); left:50%;
            transform:translateX(-50%); background:#0f172a; color:#fff;
            font-size:10px; padding:3px 7px; border-radius:6px; white-space:nowrap;
            font-family:'Inter',sans-serif;
        }
        .preset:hover .preset-tip { display:block; }

        .divider { height:0.5px; background:#e2e8f0; margin:18px 0; }

        /* Preview */
        .preview-wrap { border-radius:14px; overflow:hidden; border:0.5px solid #e2e8f0; }
        .prev-sb { padding:16px 12px; display:flex; flex-direction:column; gap:4px; }
        .prev-logo { font-size:15px; font-weight:700; padding:0 6px; margin-bottom:14px; }
        .prev-logo small { display:block; font-size:8px; opacity:0.55; font-weight:400; letter-spacing:0.07em; text-transform:uppercase; margin-top:1px; }
        .prev-ni { display:block; padding:8px 10px; border-radius:8px; font-size:11px; font-weight:500; border-left:3px solid transparent; }
        .prev-ni.on { font-weight:600; }
        .prev-ndiv { height:1px; margin:4px 6px; }
        .prev-main { flex:1; background:#f8fafc; }
        .prev-topbar { padding:12px 16px; display:flex; justify-content:space-between; align-items:center; }
        .prev-title { font-size:16px; font-weight:700; }
        .prev-sub { font-size:10px; margin-top:2px; }
        .prev-badge { padding:5px 12px; border-radius:50px; font-size:10px; font-weight:600; border:1px solid; }
        .prev-content { padding:12px; }
        .prev-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:7px; margin-bottom:8px; }
        .prev-card { background:#fff; border-radius:10px; padding:11px; border:0.5px solid #e2e8f0; position:relative; overflow:hidden; }
        .prev-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
        .prev-clabel { font-size:8px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:#94a3b8; margin-bottom:3px; }
        .prev-cnum { font-size:18px; font-weight:700; }
        .prev-act { background:#fff; border-radius:10px; padding:11px; border:0.5px solid #e2e8f0; }
        .prev-atitle { font-size:10px; font-weight:600; margin-bottom:8px; display:flex; align-items:center; gap:5px; }
        .prev-atitle::after { content:''; flex:1; height:0.5px; background:#e2e8f0; }
        .prev-ai { padding:6px 8px; border-radius:6px; font-size:10px; color:#334155; margin-bottom:4px; border-left:2px solid transparent; }
        .prev-ai:nth-child(odd) { background:#f8fafc; }
        .prev-ai:nth-child(even) { background:#f0fdfb; }
        .prev-ai:last-child { margin-bottom:0; }

        /* Botones */
        .btn-save {
            width:100%; padding:14px; border-radius:14px; border:none;
            font-size:14px; font-weight:600; cursor:pointer;
            font-family:'Inter',sans-serif; margin-top:4px;
            transition:all 0.2s; color:#fff;
        }
        .btn-save:hover { opacity:0.9; transform:translateY(-2px); }
        .btn-reset {
            width:100%; padding:11px; border-radius:14px;
            font-size:13px; font-weight:500; cursor:pointer;
            font-family:'Inter',sans-serif; margin-top:8px;
            background:#f8fafc; border:0.5px solid #e2e8f0; color:#64748b;
            transition:all 0.2s;
        }
        .btn-reset:hover { background:#f1f5f9; }

        .toast {
            position:fixed; bottom:28px; right:28px;
            background:#0f172a; color:#fff; padding:12px 20px;
            border-radius:12px; font-size:13px; font-weight:500;
            opacity:0; transform:translateY(10px);
            transition:all 0.3s; pointer-events:none; z-index:100;
        }
        .toast.show { opacity:1; transform:translateY(0); }

        .back-btn {
            position:fixed; top:18px; left:258px;
            background:rgba(10,61,56,0.7); border:1px solid rgba(46,196,182,0.3);
            color:#2EC4B6; padding:7px 15px; border-radius:50px;
            font-size:12px; font-weight:500; cursor:pointer; z-index:20;
            transition:all 0.2s; font-family:'Inter',sans-serif;
        }
    </style>
</head>
